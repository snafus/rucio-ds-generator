# .env.template — copy to .env and fill in real values.
# .env is git-ignored; this template is safe to commit.
#
# These values are loaded automatically by dataset-generator at startup.
# Environment variables set in the shell always take precedence over this file.

# ---------------------------------------------------------------------------
# Rucio client configuration file path
#
# Rucio's client library requires a rucio.cfg before it will start.
# Create a minimal one (see README § Configuration) then set RUCIO_CONFIG
# to its absolute path.
#
# If RUCIO_CONFIG is unset, Rucio searches (in order):
#   $VIRTUAL_ENV/etc/rucio.cfg
#   /opt/rucio/etc/rucio.cfg
# ---------------------------------------------------------------------------
RUCIO_CONFIG=/path/to/rucio.cfg

# ---------------------------------------------------------------------------
# Rucio server endpoints
# ---------------------------------------------------------------------------
RUCIO_HOST=https://rucio.example.org
RUCIO_AUTH_HOST=https://rucio-auth.example.org
RUCIO_ACCOUNT=your-rucio-account

# ---------------------------------------------------------------------------
# OIDC client credentials (client_credentials grant)
#
# The tool obtains a bearer token via the OAuth2 client_credentials grant
# and injects it into the Rucio client.  The token is refreshed automatically
# (using the same client_id/secret) before it expires, so long-running jobs
# stay authenticated without manual intervention.
# ---------------------------------------------------------------------------
OIDC_TOKEN_ENDPOINT=https://iam.example.org/token
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
